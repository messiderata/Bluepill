{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build test firmware (Docker)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/docker-make.sh",
      "args": [
        "-j"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Clean test firmware (Docker)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/docker-make.sh",
      "args": [
        "clean"
      ],
      "problemMatcher": []
    },
    {
      "label": "Rebuild test firmware (Docker)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Clean test firmware (Docker)",
        "Build test firmware (Docker)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Start OpenOCD GDB Server (Docker)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/docker-openocd.sh",
      "args": [
        "-f",
        "interface/jlink.cfg",
        "-c",
        "transport select swd",
        "-f",
        "target/stm32f1x.cfg",
        "-c",
        "adapter speed 1000"
      ],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Open On-Chip Debugger",
          "endsPattern": "Listening on port 3333 for gdb connections"
        }
      }
    },
    {
      "label": "Build + Start OpenOCD GDB Server (Docker)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Build test firmware (Docker)",
        "Start OpenOCD GDB Server (Docker)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Stop OpenOCD GDB Server (Docker)",
      "type": "shell",
      "command": "docker stop $(docker ps -q --filter ancestor=${STM32_DOCKER_IMAGE:-generic-modbus-dev} --filter status=running) 2>/dev/null || true",
      "problemMatcher": []
    },
    {
      "label": "Flash test firmware (Docker OpenOCD)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/docker-openocd.sh",
      "args": [
        "-f",
        "interface/jlink.cfg",
        "-c",
        "transport select swd",
        "-f",
        "target/stm32f1x.cfg",
        "-c",
        "adapter speed 1000",
        "-c",
        "program build/bluepill.elf verify reset exit"
      ],
      "dependsOn": [
        "Build test firmware (Docker)"
      ],
      "problemMatcher": []
    }
  ]
}
